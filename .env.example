# ─── Database (Supabase / Postgres) ──────────────────────────────────────────
# Pooled connection (used at runtime by Prisma).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (used by `prisma migrate` for DDL — bypasses the pooler).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Supabase (storage / auth helpers) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# ─── Razorpay payments (replaces Stripe) ─────────────────────────────────────
# Dashboard → Account & Settings → API Keys (use TEST keys in dev).
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Dashboard → Settings → Webhooks → create webhook → copy the generated secret.
# Webhook URL must be: https://<your-domain>/api/razorpay/webhook
# Subscribe to: payment.captured, payment.failed, refund.processed
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Admin API ───────────────────────────────────────────────────────────────
# Bearer token required by POST /api/athletes (athlete onboarding by admins).
ADMIN_API_KEY="generate-a-long-random-string"

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Required in production for cross-instance limiting. Without these, the app
# falls back to in-memory limiting (per-instance only — won't stop a real
# attacker, but is fine for dev/local). Create a free DB at upstash.com.
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
