// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ATHLETE
  SCHOOL
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REJECTED
}

enum SessionType {
  WORKSHOP
  TALK
  TRAINING
}

enum EscrowStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
}

enum NotificationType {
  SMS
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ─── User (unified auth) ─────────────────────────────────────────────────────

model User {
  id             String         @id @default(cuid())
  role           Role
  username       String?        @unique
  phone          String?        @unique
  password       String?        // bcrypt hash
  resetOtp       String?
  resetOtpExpiry DateTime?

  athleteId      String?        @unique
  athlete        Athlete?       @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  schoolId       String?        @unique
  school         School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  notifications  Notification[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
}

// ─── Athlete ─────────────────────────────────────────────────────────────────

model Athlete {
  id               String        @id @default(cuid())
  user             User?
  name             String
  sport            String
  bio              String?
  pricingSession   Decimal       @db.Decimal(10,2) @default(10000.00)
  currency         String        @default("INR")
  isVerified       Boolean       @default(false)
  avatarUrl        String?
  aadhaarLastFour  String?
  federationId     String?
  kheloIndiaId     String?
  verificationDocs String[]

  achievements     Achievement[]
  bookings         Booking[]
  reviews          Review[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  @@index([sport, isVerified])
  @@index([deletedAt])
}

// ─── Achievement ─────────────────────────────────────────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  title       String
  description String?
  year        Int?
  isVerified  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([athleteId])
}

// ─── School ──────────────────────────────────────────────────────────────────

model School {
  id        String    @id @default(cuid())
  user      User?
  name      String
  city      String
  contact   String?

  bookings  Booking[]
  reviews   Review[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// ─── Session (event type template per booking) ───────────────────────────────

model Session {
  id          String      @id @default(cuid())
  title       String
  description String
  durationMin Int         @default(60)
  type        SessionType @default(TALK)

  bookings    Booking[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(cuid())
  athleteId        String
  schoolId         String
  sessionId        String
  date             DateTime
  status           BookingStatus @default(PENDING)
  audienceSize     Int?
  schoolType       String?
  schoolNote       String?
  // Price locked at booking time — prevents history rewrite if athlete changes fee
  pricingSnapshot  Decimal?      @db.Decimal(10,2)

  athlete          Athlete            @relation(fields: [athleteId], references: [id])
  school           School             @relation(fields: [schoolId], references: [id])
  session          Session            @relation(fields: [sessionId], references: [id])
  escrow           EscrowTransaction?
  reviews          Review[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  @@index([athleteId])
  @@index([schoolId])
  @@index([sessionId])
  @@index([date])
  @@index([status])
  @@index([athleteId, status])  // covers the most common query pattern
}

// ─── Escrow ──────────────────────────────────────────────────────────────────

model EscrowTransaction {
  id                 String       @id @default(cuid())
  bookingId          String       @unique
  booking            Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount             Decimal      @db.Decimal(10,2)
  currency           String       @default("INR")
  status             EscrowStatus @default(PENDING)

  // Razorpay identifiers for audit trail, refunds, and transfers (Route)
  razorpayOrderId    String?
  razorpayPaymentId  String?
  razorpayRefundId   String?
  razorpayTransferId String?      // set when payout is triggered (Razorpay Route)

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?
}

// ─── Review ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  athleteId String
  schoolId  String
  bookingId String   @unique  // one review per completed booking
  rating    Int      // 1–5
  comment   String?

  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([athleteId])
  @@index([schoolId])
}

// ─── Notification ────────────────────────────────────────────────────────────

model Notification {
  id      String             @id @default(cuid())
  userId  String
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title   String
  message String
  type    NotificationType
  status  NotificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId, status])
  @@index([userId])
}
